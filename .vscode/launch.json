{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run Main",
            "type": "debugpy",
            "request": "launch",
            "module": "dns_synchub",
            "console": "integratedTerminal",
            "args": [
                "--env-file",
                "${workspaceFolder}/.env",
